---
import LinkedInIcon from "./icons/LinkedIn.astro";
import MailIcon from "./icons/Mail.astro";
import Pill from "./Pill.astro";
import SectionHeader from "./SectionHeader.astro";
---

<div class="max-w-4xl mx-auto px-4">
  <SectionHeader
    badge="Contact"
    title="Let's Connect"
    subtitle="Ready to collaborate on exciting projects? Let's discuss your next idea!"
  />
  <div class="flex justify-center gap-4 flex-wrap -mt-8">
    <Pill href="https://www.linkedin.com/in/pedro-luis-ruiz/">
      <LinkedInIcon class="size-4 md:size-6" /> LinkedIn
    </Pill>
    <Pill href="mailto:pruiz.rd@gmail.com">
      <MailIcon class="size-4 md:size-6" /> Email
    </Pill>
  </div>
</div>
